# =============================================================================
# SafeSign ICU Monitoring System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Format: postgresql://username:password@host:port/database_name
DB_USER=postgres
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=5432
DB_NAME=icu_alert_database

# Alternative: Full DATABASE_URL (uncomment and set if preferred)
# DATABASE_URL=postgresql://postgres:root@localhost:5432/icu_alert_database

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Debug mode (True/False)
DEBUG=False

# -----------------------------------------------------------------------------
# Telegram Bot Configuration (Optional)
# -----------------------------------------------------------------------------
# Get bot token from @BotFather on Telegram
# Get chat ID from @userinfobot or your bot's chat ID
BOT_TOKEN=
CHAT_ID=

# -----------------------------------------------------------------------------
# Camera Configuration (Optional)
# -----------------------------------------------------------------------------
# Set to True to use DroidCam instead of default camera
USE_DROIDCAM=False
DROIDCAM_IP=10.95.126.251
DROIDCAM_PORT=4747

# -----------------------------------------------------------------------------
# JWT Configuration (Optional - defaults in auth/jwt_handler.py)
# -----------------------------------------------------------------------------
# JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60

